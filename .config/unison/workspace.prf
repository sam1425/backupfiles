root = /home/c0mplex/Documents/Programming
root = ssh://home//home/c0mplex/Documents/Programming

# repeat = watch
repeat = 60
auto = true
batch = true
prefer = newer

# Ignore dev stuff
ignore = Name .git
ignore = Name .git/*
ignore = Name node_modules
ignore = Name build
ignore = Name dist
ignore = Name target
ignore = Name __pycache__
ignore = Name *.o
ignore = Name *.out
ignore = Name *.exe
ignore = Name *.obj
ignore = Name *.class
